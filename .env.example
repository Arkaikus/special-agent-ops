# Gateway (optional overrides; defaults work for local sqlite + redis)
GATEWAY_DATABASE_URL=sqlite:///./data/gateway.db
GATEWAY_REDIS_URL=redis://localhost:6379/0
GATEWAY_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Agents (examples)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1

# Frontend (see frontend/.env.example)
# VITE_GATEWAY_URL=http://localhost:8000
