[project]
name = "generated-agent-{{ agent_name }}"
version = "0.0.0"
requires-python = ">=3.13"
dependencies = [
    "fastapi>=0.115",
    "uvicorn[standard]>=0.32",
    "pydantic-ai>=1.0",
    "redis>=5.2",
    "httpx>=0.27",
{% if has_mcp %}
    "mcp>=1.0",
{% endif %}
]

[project.scripts]
run-agent = "server:main"
