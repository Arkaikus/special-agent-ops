from __future__ import annotations

import os
from contextlib import asynccontextmanager

from fastapi import FastAPI
from pydantic import BaseModel, Field
from pydantic_ai import Agent
{% if model.provider == "anthropic" %}
from pydantic_ai.models.anthropic import AnthropicModel
{% elif model.provider == "ollama" %}
from pydantic_ai.models.ollama import OllamaModel
from pydantic_ai.providers.ollama import OllamaProvider
{% else %}
from pydantic_ai.models.openai import OpenAIChatModel
from pydantic_ai.providers.openai import OpenAIProvider
{% endif %}
{% if has_mcp %}
from pydantic_ai.mcp import MCPServerHTTP, MCPServerStdio, MCPServerSSE
{% endif %}
{% if has_fs %}
import workspace_tools
{% endif %}

PORT = int(os.environ.get("PORT", "{{ port }}"))
REDIS_URL = os.environ.get("REDIS_URL", "redis://redis:6379/0")
MCP_SERVERS = {{ mcp_servers_literal }}
_FS_ALLOW = {{ fs_allow_literal }}


def _mcp_http_headers(entry: dict) -> dict | None:
    h = dict(entry.get("headers") or {})
    b = entry.get("bearerFromEnv")
    if b:
        t = os.environ.get(b, "")
        h["Authorization"] = f"Bearer {t}"
    return h or None


def _build_toolsets():
{% if has_mcp %}
    toolsets = []
    for entry in MCP_SERVERS:
        name = entry.get("name") or "mcp"
        transport = entry.get("transport") or "stdio"
        if transport == "stdio" and entry.get("command"):
            toolsets.append(
                MCPServerStdio(
                    entry["command"],
                    entry.get("args") or [],
                    tool_prefix=name,
                    env=os.environ.copy(),
                )
            )
        elif transport == "sse" and entry.get("url"):
            hdrs = _mcp_http_headers(entry)
            toolsets.append(MCPServerSSE(entry["url"], tool_prefix=name, headers=hdrs))
        elif transport == "http" and entry.get("url"):
            hdrs = _mcp_http_headers(entry)
            toolsets.append(MCPServerHTTP(entry["url"], tool_prefix=name, headers=hdrs))
    return toolsets
{% else %}
    return []
{% endif %}


def _build_fs_tools():
{% if has_fs %}
    reg = {
        "ls": workspace_tools.tool_ls,
        "grep": workspace_tools.tool_grep,
        "edit": workspace_tools.tool_edit,
        "glob": workspace_tools.tool_glob,
        "bash": workspace_tools.tool_bash,
    }
    return [reg[k] for k in _FS_ALLOW if k in reg]
{% else %}
    return []
{% endif %}


def build_agent() -> Agent[None, str]:
    system_prompt = """{{ system_prompt | e }}"""
{% if model.provider == "anthropic" %}
    _ = os.environ.get("{{ model.api_key_env }}")
    model = AnthropicModel("{{ model.model_id }}")
{% elif model.provider == "ollama" %}
    model = OllamaModel(
        "{{ model.model_id }}",
        provider=OllamaProvider(base_url="{{ model.base_url }}"),
    )
{% else %}
    _key = (
        os.environ.get("{{ model.api_key_env }}", "sk-local")
        if "{{ model.api_key_env }}"
        else "sk-local"
    )
    model = OpenAIChatModel(
        "{{ model.model_id }}",
        provider=OpenAIProvider(base_url="{{ model.base_url }}", api_key=_key),
    )
{% endif %}
    toolsets = _build_toolsets()
    tools = _build_fs_tools()
    kw: dict = {"model": model, "system_prompt": system_prompt}
    if toolsets:
        kw["toolsets"] = toolsets
    if tools:
        kw["tools"] = tools
    return Agent(**kw)


_agent: Agent[None, str] | None = None


@asynccontextmanager
async def lifespan(app: FastAPI):
    global _agent
    _agent = build_agent()
    yield
    _agent = None


app = FastAPI(title="{{ agent_name }}", lifespan=lifespan)


class InvokeBody(BaseModel):
    message: str = Field(..., min_length=1)
    context: dict | None = None


@app.get("/health")
async def health():
    return {"status": "ok", "agent": "{{ agent_name }}"}


@app.post("/invoke")
async def invoke(body: InvokeBody):
    assert _agent is not None
    result = await _agent.run(body.message)
    return {"output": result.output}
